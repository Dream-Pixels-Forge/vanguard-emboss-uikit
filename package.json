{
  "name": "vanguard-emboss-uikit",
  "version": "0.5.1",
  "description": "Premium neumorphic (soft UI) React component library with 45° light-source emboss effects. Built with Radix UI primitives and Tailwind CSS.",
  "author": "Dream Pixels Forge (https://github.com/Dream-Pixels-Forge)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Dream-Pixels-Forge/vanguard-emboss-uikit.git"
  },
  "bugs": {
    "url": "https://github.com/Dream-Pixels-Forge/vanguard-emboss-uikit/issues"
  },
  "homepage": "https://github.com/Dream-Pixels-Forge/vanguard-emboss-uikit#readme",
  "keywords": [
    "react",
    "ui-kit",
    "components",
    "neumorphism",
    "soft-ui",
    "emboss",
    "tailwindcss",
    "radix-ui",
    "typescript",
    "design-system"
  ],
  "main": "./dist/vanguard-emboss-uikit.cjs.js",
  "module": "./dist/vanguard-emboss-uikit.es.js",
  "types": "./dist/components/ui/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/components/ui/index.d.ts",
      "import": "./dist/vanguard-emboss-uikit.es.js",
      "require": "./dist/vanguard-emboss-uikit.cjs.js"
    },
    "./styles": {
      "import": "./dist/style.css",
      "require": "./dist/style.css"
    }
  },
  "files": [
    "dist",
    "registry",
    "README.md"
  ],
  "type": "module",
  "size-limit": [
    {
      "path": "dist/vanguard-emboss-uikit.es.js",
      "limit": "40 KB",
      "import": "{ Button }",
      "ignore": [
        "react",
        "react-dom",
        "react/jsx-runtime",
        "class-variance-authority",
        "clsx",
        "tailwind-merge",
        "lucide-react",
        "sonner",
        "tailwindcss-animate",
        "@radix-ui/react-accordion",
        "@radix-ui/react-checkbox",
        "@radix-ui/react-dialog",
        "@radix-ui/react-dropdown-menu",
        "@radix-ui/react-label",
        "@radix-ui/react-navigation-menu",
        "@radix-ui/react-popover",
        "@radix-ui/react-radio-group",
        "@radix-ui/react-select",
        "@radix-ui/react-slider",
        "@radix-ui/react-slot",
        "@radix-ui/react-switch",
        "@radix-ui/react-tabs",
        "@radix-ui/react-tooltip",
        "@radix-ui/react-progress",
        "@radix-ui/react-avatar",
        "@radix-ui/react-toggle-group",
        "@radix-ui/react-collapsible",
        "@radix-ui/react-alert-dialog",
        "@radix-ui/react-toggle",
        "@radix-ui/react-hover-card",
        "@radix-ui/react-menubar",
        "@radix-ui/react-aspect-ratio",
        "cmdk",
        "react-day-picker",
        "date-fns",
        "embla-carousel-react",
        "@tanstack/react-table",
        "react-resizable-panels",
        "recharts",
        "input-otp",
        "@radix-ui/react-scroll-area",
        "vaul",
        "@radix-ui/react-context-menu",
        "react-hook-form",
        "@hookform/resolvers"
      ]
    }
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:registry": "tsx scripts/generate-registry.ts",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "type-check": "tsc --noEmit",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css}\"",
    "size": "size-limit",
    "clean": "rm -rf dist node_modules/.vite",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-aspect-ratio": "^1.1.8",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.3.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.16.0",
    "react-day-picker": "^10.0.1",
    "react-resizable-panels": "^4.11.2",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "vaul": "^1.1.2"
  },
  "peerDependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.2.1",
    "@hookform/resolvers": "^5.4.0",
    "@size-limit/preset-small-lib": "^12.1.0",
    "@storybook/addon-a11y": "^10.4.1",
    "@storybook/addon-docs": "^10.4.1",
    "@storybook/addon-mcp": "^0.6.0",
    "@storybook/addon-themes": "^10.4.1",
    "@storybook/addon-vitest": "^10.4.1",
    "@storybook/react": "^10.4.1",
    "@storybook/react-vite": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.9.1",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "@vitest/browser": "3.2.4",
    "@vitest/coverage-v8": "3.2.4",
    "autoprefixer": "^10.5.0",
    "eslint": "^8.45.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.0",
    "eslint-plugin-storybook": "^10.4.1",
    "happy-dom": "^20.9.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.60.0",
    "postcss": "^8.5.15",
    "prettier": "^3.8.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.76.1",
    "size-limit": "^12.1.0",
    "storybook": "^10.4.1",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.22.3",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^5.0.1",
    "vitest": "^3.2.4",
    "zod": "^4.4.3"
  }
}
